msgid "VR-Frases Widget (VR_Frases_Widget):"
msgstr "VR-Frases Widget (VR_Frases_Widget):"

#: admin/vr-frases-options.php:298
msgid "Displays a random quote on each page reload."
msgstr "Muestra una frase aleatoria en cada recarga de página."

#: admin/vr-frases-options.php:301
msgid "VR-Frases Dashboard Widget (vr_frases_dash_widget):"
msgstr "VR-Frases Dashboard Widget (vr_frases_dash_widget):"

#: admin/vr-frases-options.php:302
msgid ""
"Displays in the WordPress admin dashboard a summary of the data (total "
"quotes, authors, topics, classes), a random sample quote, and the plugin "
"version."
msgstr ""
